SECRET_KEY=your-django-secret-key-change-this-in-production
DEBUG=True

# Paystack — get these from dashboard.paystack.com > Settings > API Keys
# Use TEST keys while developing — no real money moves
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Where Paystack redirects after payment (your frontend)
PAYSTACK_CALLBACK_URL=http://localhost:3000/book/payment-callback

# JWT lifetimes
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
